{
  "info": {
    "name": "Library REST API – Happy Path",
    "description": "Happy path tests for the REST Library API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "REST_BASE",
      "value": "http://localhost:8000"
    }
  ],
  "item": [
    {
      "name": "Root health check",
      "request": {
        "method": "GET",
        "url": "{{REST_BASE}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has message field', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property('message');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Authors",
      "item": [
        {
          "name": "Create Author",
          "request": {
            "method": "POST",
            "url": "{{REST_BASE}}/authors",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"George\", \"surname\": \"Orwell\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response structure', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('name');",
                  "    pm.expect(body).to.have.property('surname');",
                  "    pm.expect(body.name).to.eql('George');",
                  "    pm.expect(body.surname).to.eql('Orwell');",
                  "});",
                  "pm.collectionVariables.set('author_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Author by ID",
          "request": {
            "method": "GET",
            "url": "{{REST_BASE}}/authors/{{author_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response structure', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('name');",
                  "    pm.expect(body).to.have.property('surname');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Authors",
          "request": {
            "method": "GET",
            "url": "{{REST_BASE}}/authors"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('Items have correct structure', () => {",
                  "    const items = pm.response.json();",
                  "    if (items.length > 0) {",
                  "        pm.expect(items[0]).to.have.property('id');",
                  "        pm.expect(items[0]).to.have.property('name');",
                  "        pm.expect(items[0]).to.have.property('surname');",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Author",
          "request": {
            "method": "PUT",
            "url": "{{REST_BASE}}/authors/{{author_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Eric\", \"surname\": \"Blair\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response structure', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body.name).to.eql('Eric');",
                  "    pm.expect(body.surname).to.eql('Blair');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
