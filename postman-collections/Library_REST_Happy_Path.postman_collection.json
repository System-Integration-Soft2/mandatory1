    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "url": "{{REST_BASE}}/books",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"1984\", \"author_id\": {{author_id}}, \"publisher_id\": {{publisher_id}}, \"publishing_year\": 1949}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response structure', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('title');",
                  "    pm.expect(body).to.have.property('author_id');",
                  "    pm.expect(body).to.have.property('publisher_id');",
                  "    pm.expect(body).to.have.property('publishing_year');",
                  "    pm.expect(body.title).to.eql('1984');",
                  "    pm.expect(body.publishing_year).to.eql(1949);",
                  "});",
                  "pm.collectionVariables.set('book_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Book by ID",
          "request": {
            "method": "GET",
            "url": "{{REST_BASE}}/books/{{book_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response structure', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('title');",
                  "    pm.expect(body).to.have.property('author_id');",
                  "    pm.expect(body).to.have.property('publisher_id');",
                  "    pm.expect(body).to.have.property('publishing_year');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{REST_BASE}}/books?limit=20&offset=0",
              "host": ["{{REST_BASE}}"],
              "path": ["books"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('Items have correct structure', () => {",
                  "    const items = pm.response.json();",
                  "    if (items.length > 0) {",
                  "        pm.expect(items[0]).to.have.property('id');",
                  "        pm.expect(items[0]).to.have.property('title');",
                  "        pm.expect(items[0]).to.have.property('author_id');",
                  "        pm.expect(items[0]).to.have.property('publisher_id');",
                  "        pm.expect(items[0]).to.have.property('publishing_year');",
                  "    }",
                  "});"
                ]
