{
  "info": {
    "name": "Library GraphQL API – Happy Path",
    "description": "Happy path tests for the GraphQL Library API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "GQL_BASE",
      "value": "http://localhost:8001/graphql"
    }
  ],
  "item": [
    {
      "name": "Authors",
      "item": [
        {
          "name": "Create Author",
          "request": {
            "method": "POST",
            "url": "{{GQL_BASE}}",
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation { createAuthor(input: { name: \"Jane\", surname: \"Austen\" }) { id name surname } }",
                "variables": ""
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('No errors', () => {",
                  "    pm.expect(pm.response.json()).to.not.have.property('errors');",
                  "});",
                  "pm.test('Response structure', () => {",
                  "    const data = pm.response.json().data.createAuthor;",
                  "    pm.expect(data).to.have.property('id');",
                  "    pm.expect(data).to.have.property('name');",
                  "    pm.expect(data).to.have.property('surname');",
                  "    pm.expect(data.name).to.eql('Jane');",
                  "    pm.expect(data.surname).to.eql('Austen');",
                  "});",
                  "pm.collectionVariables.set('author_id', pm.response.json().data.createAuthor.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "List Authors",
          "request": {
            "method": "POST",
            "url": "{{GQL_BASE}}",
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{ authors { id name surname } }",
                "variables": ""
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('No errors', () => {",
                  "    pm.expect(pm.response.json()).to.not.have.property('errors');",
                  "});",
                  "pm.test('Response structure', () => {",
                  "    const authors = pm.response.json().data.authors;",
                  "    pm.expect(authors).to.be.an('array');",
                  "    if (authors.length > 0) {",
                  "        pm.expect(authors[0]).to.have.property('id');",
                  "        pm.expect(authors[0]).to.have.property('name');",
                  "        pm.expect(authors[0]).to.have.property('surname');",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Author",
          "request": {
            "method": "POST",
            "url": "{{GQL_BASE}}",
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation ($id: Int!) { updateAuthor(id: $id, input: { name: \"Jane\", surname: \"Austen-Leigh\" }) { id name surname } }",
                "variables": "{\"id\": {{author_id}}}"
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
