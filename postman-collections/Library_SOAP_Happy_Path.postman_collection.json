{
  "info": {
    "name": "Library SOAP API – Happy Path",
    "description": "Happy path tests for the SOAP Library API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "SOAP_BASE",
      "value": "http://localhost:8080/soap/LibraryService"
    }
  ],
  "item": [
    {
      "name": "Authors",
      "item": [
        {
          "name": "Create Author",
          "request": {
            "method": "POST",
            "url": "{{SOAP_BASE}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/xml"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\">\n  <soap:Body>\n    <ns2:createAuthor xmlns:ns2=\"http://library.org/soap\">\n      <name>George</name>\n      <surname>Orwell</surname>\n    </ns2:createAuthor>\n  </soap:Body>\n</soap:Envelope>"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains return (ID)', () => {",
                  "    const xml = pm.response.text();",
                  "    pm.expect(xml).to.include('<return>');",
                  "    const match = xml.match(/<return>(\\d+)<\\/return>/);",
                  "    pm.expect(match).to.not.be.null;",
                  "    pm.collectionVariables.set('author_id', match[1]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Author by ID",
          "request": {
            "method": "POST",
            "url": "{{SOAP_BASE}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/xml"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\">\n  <soap:Body>\n    <ns2:getAuthorById xmlns:ns2=\"http://library.org/soap\">\n      <id>{{author_id}}</id>\n    </ns2:getAuthorById>\n  </soap:Body>\n</soap:Envelope>"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains author fields', () => {",
                  "    const xml = pm.response.text();",
                  "    pm.expect(xml).to.include('<name>');",
                  "    pm.expect(xml).to.include('<surname>');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Authors",
          "request": {
            "method": "POST",
