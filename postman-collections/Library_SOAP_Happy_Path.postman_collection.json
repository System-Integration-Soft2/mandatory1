              "mode": "raw",
              "raw": "<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\">\n  <soap:Body>\n    <ns2:updateAuthor xmlns:ns2=\"http://library.org/soap\">\n      <id>{{author_id}}</id>\n      <name>Eric</name>\n      <surname>Blair</surname>\n    </ns2:updateAuthor>\n  </soap:Body>\n</soap:Envelope>"
